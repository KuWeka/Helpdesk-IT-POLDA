# ===== Server Configuration =====
NODE_ENV=development
PORT=3001
APP_NAME=Helpdesk IT API
APP_VERSION=1.0.0

# ===== Database Configuration =====
DB_HOST=localhost
DB_PORT=3306
DB_USER=helpdesk_user
DB_PASSWORD=helpdesk_pass
# Alias fallback supported by backend config
DB_PASS=helpdesk_pass
DB_NAME=helpdesk
MYSQL_ROOT_PASSWORD=rootpassword

# ===== Redis Configuration =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ===== JWT Configuration =====
# IMPORTANT: Both secrets MUST be set, at least 32 chars, and DIFFERENT from each other.
# Generate secure random keys:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_a_random_32plus_char_secret
JWT_REFRESH_SECRET=change_me_to_a_different_random_32plus_char_secret
JWT_EXPIRES=1h
JWT_REFRESH_EXPIRES=7d
ACCESS_TOKEN_COOKIE_NAME=helpdesk_access_token
REFRESH_TOKEN_COOKIE_NAME=helpdesk_refresh_token
CSRF_COOKIE_NAME=helpdesk_csrf_token

# ===== Database Connection Pool =====
DB_CONNECTION_LIMIT=10
DB_QUEUE_LIMIT=50

# ===== Security =====
BCRYPT_ROUNDS=10

# ===== Seed Admin (used by: node scripts/setup-db.js --seed-admin) =====
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=ChangeMe!SecurePass123
# SEED_ADMIN_NAME=Administrator
# SEED_ADMIN_USERNAME=admin

# ===== Logging Configuration =====
LOG_LEVEL=info
GIT_SHA=local

# ===== API Docs (Swagger) =====
# default: enabled in development, disabled in production
ENABLE_SWAGGER=true

# ===== CORS Configuration =====
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ===== File Upload Configuration =====
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,docx,xlsx

# ===== Rate Limiting =====
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100

# ===== Session Configuration =====
SESSION_SECRET=your_session_secret_key

# ===== Socket.IO Configuration =====
SOCKET_PING_INTERVAL=25000
SOCKET_PING_TIMEOUT=5000

# Timeout (menit) untuk Padal merespons assignment sebelum otomatis dibatalkan
ASSIGNMENT_TIMEOUT_MINUTES=30

# ===== Optional Integrations =====
# Email Configuration (for notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=no-reply@helpdesk.com

# WhatsApp Integration (for technician notifications)
# WHATSAPP_API_KEY=your_api_key
# WHATSAPP_API_URL=https://api.whatsapp.com
